{
  "name": "telegram-scraper-admin",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --workspace web run dev",
    "dev:worker": "npm --workspace worker run dev",
    "build": "npm run --workspaces build",
    "lint": "npm run --workspaces lint",
    "typecheck": "npm run --workspaces typecheck"
  }
}
